+// ATLAS PC-202: per-layer residual stream capture for hidden-states extension.
+// Filled by update_slots() before llama_decode (from the union of hidden_states_layers
+// across active embedding slots), populated by atlas_capture_cb_eval during decode,
+// then consumed by send_embedding which slices per-slot tokens out of the captured
+// flat buffers. Cleared at the end of each update_slots iteration.
+struct atlas_hidden_states_capture {
+    std::set<int>                       layers_wanted;   // union across active slots
+    std::map<int, std::vector<float>>   captured;        // layer -> flat [hidden_dim * batch_n_tokens]
+    int32_t                             hidden_dim = 0;
+    int32_t                             batch_n_tokens = 0;
+
+    void clear() {
+        layers_wanted.clear();
+        captured.clear();
+        hidden_dim = 0;
+        batch_n_tokens = 0;
+    }
+};
+
+// cb_eval callback installed at server init. Called for each ggml node during decode.
+// Two-phase: ask=true asks whether to materialize data, ask=false delivers it.
+// Always returns true (returning false would abort graph compute).
+static bool atlas_capture_cb_eval(struct ggml_tensor * t, bool ask, void * user_data) {
+    auto * cap = static_cast<atlas_hidden_states_capture *>(user_data);
+    if (cap == nullptr || cap->layers_wanted.empty()) {
+        return true;  // not capturing this batch — let compute proceed
+    }
+    // Match "l_out-{N}" (post-block residual; verified against Qwen3.5-9B GGUF
+    // — both attention and DeltaNet blocks produce this name).
+    if (std::strncmp(t->name, "l_out-", 6) != 0) {
+        return true;
+    }
+    const int layer_idx = std::atoi(t->name + 6);
+    if (cap->layers_wanted.find(layer_idx) == cap->layers_wanted.end()) {
+        return true;
+    }
+    if (ask) {
+        return true;  // yes, materialize this tensor's data
+    }
+    // ask=false: data is materialized — copy it out (tensor may be on GPU,
+    // ggml_backend_tensor_get handles the device->host copy).
+    if (t->type != GGML_TYPE_F32) {
+        return true;  // unexpected dtype; skip rather than corrupt the buffer
+    }
+    const size_t n = ggml_nelements(t);
+    auto & buf = cap->captured[layer_idx];
+    buf.resize(n);
+    ggml_backend_tensor_get(t, buf.data(), 0, n * sizeof(float));
+    return true;
+}
