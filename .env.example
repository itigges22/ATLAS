# ATLAS Docker Compose Configuration  —  DOCKER COMPOSE DEPLOYMENT
#
# This file is read ONLY by `docker compose`. It is NOT read by the
# K3s installer (./scripts/install.sh) — that path uses atlas.conf.
# Values placed in atlas.conf are silently ignored by the docker
# path. See ISSUES.md PC-021.
#
# Copy to .env and adjust for your setup:  cp .env.example .env

# Path to GGUF model weights on host
ATLAS_MODELS_DIR=./models

# Model filename (must exist in ATLAS_MODELS_DIR)
ATLAS_MODEL_FILE=Qwen3.5-9B-Q6_K.gguf

# Model name (for API responses)
ATLAS_MODEL_NAME=Qwen3.5-9B-Q6_K

# Context window size (tokens)
ATLAS_CTX_SIZE=32768

# Host project directory bind-mounted to /workspace inside the proxy container.
# This is the directory ATLAS reads and writes files in. The bind mount is
# resolved at `docker compose up` time and is fixed for the container's
# lifetime. To switch projects:
#   ATLAS_PROJECT_DIR=/path/to/proj docker compose up -d --force-recreate atlas-proxy
# Defaults to the directory you ran `docker compose` from.
# ATLAS_PROJECT_DIR=/path/to/your/project

# Service ports (change if you have conflicts)
ATLAS_LLAMA_PORT=8080
ATLAS_LENS_PORT=8099
ATLAS_V3_PORT=8070
ATLAS_SANDBOX_PORT=30820
ATLAS_PROXY_PORT=8090
