# ATLAS Docker Compose configuration.
# Copy to .env and adjust for your setup:  cp .env.example .env
#
# All ATLAS services now run on vLLM. Two vLLM instances run side by side:
#   vllm-gen   — chat completions / completions  (port 8000)
#   vllm-embed — /v1/embeddings (4096-dim hidden states for the Lens, port 8001)

# ---- Model location ----------------------------------------------------------

# Where the AWQ-quantized model lives on the host. Mounted read-only into the
# vllm-gen and vllm-embed containers at /models. ~12 GiB on disk.
# Default: ./models. To populate it once:
#   pip install huggingface_hub
#   huggingface-cli download QuantTrio/Qwen3.5-9B-AWQ --local-dir ./models/Qwen3.5-9B-AWQ
ATLAS_MODELS_DIR=./models
ATLAS_MODEL_PATH=/models/Qwen3.5-9B-AWQ

# served-model-name on each vLLM instance — what code sends in the "model"
# field of /v1/{chat,completions,embeddings} requests. These MUST match the
# values used by the runners (benchmark/runner.py, benchmarks/v301_runner.py,
# v3-service, etc.).
ATLAS_GEN_MODEL_NAME=qwen3.5-9b
ATLAS_EMBED_MODEL_NAME=qwen3.5-9b-embed

# ---- vLLM tuning -------------------------------------------------------------

# H100 80GB sweet spot. Drop to 4-8 seqs / 16K ctx / 0.5 mem-util on a 16GB
# consumer card; or run gen-only with GEOMETRIC_LENS_ENABLED=false.
ATLAS_GEN_MAX_NUM_SEQS=32
ATLAS_GEN_CTX_SIZE=32768
ATLAS_GEN_GPU_MEM=0.55

ATLAS_EMBED_MAX_NUM_SEQS=8
ATLAS_EMBED_CTX_SIZE=4096
ATLAS_EMBED_GPU_MEM=0.20

# Qwen3.5 GDN block alignment requires --max-num-batched-tokens >= 2096.
# When chunked-prefill auto-disables (which v1 does for Qwen3.5), it must
# also be >= max-model-len or vLLM rejects long prompts. Defaults match
# max-model-len in docker-compose; override here to trade off prefill VRAM
# vs supporting longer prompts. See vllm-project/vllm#36697.
# ATLAS_GEN_MAX_NUM_BATCHED_TOKENS=
# ATLAS_EMBED_MAX_NUM_BATCHED_TOKENS=

# CPU swap space for vLLM (in GB). Acts as overflow when GPU memory tight.
# Recommended by the QuantTrio AWQ model card.
ATLAS_GEN_SWAP_SPACE_GB=4

# Hugging Face token for gated/private model repos. Leave empty for public
# weights (default QuantTrio/Qwen3.5-9B-AWQ is public).
# HF_TOKEN=

# ---- Project directory -------------------------------------------------------

# Mounted into the proxy container for file access. Defaults to current
# directory; set to your project path if running atlas from elsewhere.
# ATLAS_PROJECT_DIR=/path/to/your/project

# ---- Host ports (change only on conflicts) -----------------------------------

# vLLM gen + embed
ATLAS_GEN_PORT=8000
ATLAS_EMBED_PORT=8001

# Other services
ATLAS_LENS_PORT=31144
ATLAS_V3_PORT=8070
ATLAS_SANDBOX_PORT=30820
ATLAS_PROXY_PORT=8090
