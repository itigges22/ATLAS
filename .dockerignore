# Root-level dockerignore. Applies to any build that uses the repo root as
# context — currently just `v3-service` (per docker-compose.yml). Per-service
# Dockerfiles in atlas-proxy/, geometric-lens/, sandbox/, inference/ use
# their own subdirectory as context and are unaffected by this file.
#
# Goal: keep the v3 build context to just `benchmark/` + `v3-service/main.py`
# (what its Dockerfile actually COPYs), so CI doesn't ship docs/ + tests/ +
# atlas-proxy sources / etc. across the wire on every build.

# VCS + CI
.git/
.github/

# Other services' source trees (v3 doesn't need them)
atlas-proxy/
geometric-lens/
sandbox/
inference/
templates/
training_data/
plans/
docs/
tests/

# Local-only state
.atlas/
.aider*
!.aider.model.settings.yml
!.aider.model.metadata.json
.claude/
*claude*
*Claude*
CLAUDE.md
ISSUES.md
DELETE_BEFORE_PUSH/

# Heavy artifacts
models/
data/
projects/
v3_ablation_results/
v2_5_results/
v2_5_1_results/
v2_5_1/
benchmark/datasets/.cache/
benchmark/results/
benchmark/result/

# Build / cache / Python
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/
node_modules/

# Models & weights (huge, never go in any image)
*.gguf
*.bin
*.safetensors
*.pt
*.pth

# Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
*secret*
.jwt_secret
atlas.conf

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs / tmp / archives
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.backup
*.tar
*.tar.gz
*.zip
